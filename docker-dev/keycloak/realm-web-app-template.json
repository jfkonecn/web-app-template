{
  "realm": "web-app-template",
  "enabled": true,
  "displayName": "web-app-template",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator access for local development",
        "attributes": {
          "permissions": [
            "read:admin"
          ]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "web-app-template",
      "name": "web-app-template",
      "description": "Local development client for the sample app",
      "rootUrl": "http://localhost:8080",
      "baseUrl": "http://localhost:8080",
      "surrogateAuthRequired": false,
      "enabled": true,
      "alwaysDisplayInConsole": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "replace-with-a-dev-only-client-secret",
      "redirectUris": ["http://localhost:8080/callback"],
      "webOrigins": ["http://localhost:8080"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "roles",
            "id.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "permissions-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "permissions",
            "id.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "usermodel.realmRoleMapping.rolePrefix": "read:"
          }
        }
      ],
      "defaultClientScopes": ["profile", "email", "roles", "web-origins"],
      "optionalClientScopes": [
        "address",
        "microprofile-jwt",
        "offline_access",
        "phone"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Admin",
      "email": "admin@example.com",
      "realmRoles": ["admin"],
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "app",
      "enabled": true,
      "emailVerified": true,
      "firstName": "App",
      "lastName": "User",
      "email": "user@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
